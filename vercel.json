{
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap-index.js" },
    { "source": "/sitemaps/:file", "destination": "/api/sitemap.js?file=:file" },
    { "source": "/share/(.*)", "destination": "/api/share.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
